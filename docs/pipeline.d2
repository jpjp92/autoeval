###############################################################
# AutoEval — 전체 파이프라인 다이어그램
# d2 pipeline.d2 pipeline.svg --theme 0 --layout elk
###############################################################

direction: down

# ── 시작점 ──────────────────────────────────────────────────
upload: "📄 PDF / DOCX 업로드" {
  shape: oval
  style: {
    fill: "#eef2ff"
    stroke: "#6366f1"
    stroke-width: 2
    font-size: 14
    bold: true
  }
}

# ── STEP 1: 데이터 규격화 ──────────────────────────────────
s1: "STEP 1  ·  데이터 규격화" {
  style: {
    fill: "#f8fafc"
    stroke: "#6366f1"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 12
    font-size: 13
    bold: true
  }

  parse: "PyMuPDF 파싱\nSection-First 청킹" {
    style: { fill: "#eef2ff"; stroke: "#818cf8"; border-radius: 8 }
  }
  normalize: "normalize_text\n특수문자·줄바꿈·짧은 청크 정리" {
    style: { fill: "#eef2ff"; stroke: "#818cf8"; border-radius: 8 }
  }
  dedup: "content_hash\n중복 확인" {
    shape: diamond
    style: { fill: "#e0e7ff"; stroke: "#6366f1" }
  }
  embed: "Gemini Embedding 2\n1536dim 벡터화" {
    style: { fill: "#eef2ff"; stroke: "#818cf8"; border-radius: 8 }
  }
  skip1: "skip (중복)" {
    shape: oval
    style: { fill: "#f1f5f9"; stroke: "#cbd5e1"; font-color: "#94a3b8" }
  }
  db1: "Supabase\ndoc_chunks" {
    shape: cylinder
    style: { fill: "#ede9fe"; stroke: "#7c3aed" }
  }

  parse -> normalize
  normalize -> dedup
  dedup -> embed: "신규"
  dedup -> skip1: "중복"
  embed -> db1
}

# ── STEP 2: 계층 태깅 ─────────────────────────────────────
s2: "STEP 2  ·  계층 태깅 — 3-Pass Master" {
  style: {
    fill: "#f8fafc"
    stroke: "#f59e0b"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 12
    font-size: 13
    bold: true
  }

  pass1: "Pass 1: analyze-hierarchy\ndoc_chunks 샘플 → L1 master 확정" {
    style: { fill: "#fffbeb"; stroke: "#fbbf24"; border-radius: 8 }
  }
  pass2: "Pass 2: analyze-l2-l3\nL1 기반 → L2/L3 master 동시 생성" {
    style: { fill: "#fffbeb"; stroke: "#fbbf24"; border-radius: 8 }
  }
  pass3: "Pass 3: apply-granular-tagging\n청크별 master에서 선택만\n신규 생성 금지" {
    style: { fill: "#fffbeb"; stroke: "#fbbf24"; border-radius: 8 }
  }
  db2: "doc_chunks.metadata\nhierarchy_l1/l2/l3 업데이트" {
    shape: cylinder
    style: { fill: "#ede9fe"; stroke: "#7c3aed" }
  }

  pass1 -> pass2
  pass2 -> pass3
  pass3 -> db2
}

# ── STEP 3: QA 생성 ──────────────────────────────────────
s3: "STEP 3  ·  QA 생성" {
  style: {
    fill: "#f8fafc"
    stroke: "#10b981"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 12
    font-size: 13
    bold: true
  }

  filter: "L1/L2 필터 → doc_chunks 조회\nheading·colophon skip" {
    style: { fill: "#ecfdf5"; stroke: "#6ee7b7"; border-radius: 8 }
  }
  profiler: "domain_profiler\ndoc_chunks 샘플 → domain_profile\njob당 1회" {
    style: { fill: "#ecfdf5"; stroke: "#6ee7b7"; border-radius: 8 }
  }
  prompt: "적응형 프롬프트 빌드\nXML 태그 구조" {
    style: { fill: "#ecfdf5"; stroke: "#6ee7b7"; border-radius: 8 }
  }
  gen: "ThreadPoolExecutor\n병렬 생성 (4~8개 유연 조정)" {
    style: { fill: "#ecfdf5"; stroke: "#6ee7b7"; border-radius: 8 }
  }
  db3: "qa_gen_results" {
    shape: cylinder
    style: { fill: "#ede9fe"; stroke: "#7c3aed" }
  }

  filter -> profiler
  profiler -> prompt
  prompt -> gen
  gen -> db3
}

# ── STEP 4: 4레이어 평가 ─────────────────────────────────
s4: "STEP 4  ·  4레이어 평가" {
  style: {
    fill: "#f8fafc"
    stroke: "#ef4444"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 12
    font-size: 13
    bold: true
  }

  l1a: "Layer 1-A\nSyntax Validation" {
    style: { fill: "#fff1f2"; stroke: "#fca5a5"; border-radius: 8 }
  }
  l1b: "Layer 1-B\nDataset Statistics\n다양성·중복률" {
    style: { fill: "#fff1f2"; stroke: "#fca5a5"; border-radius: 8 }
  }
  l2: "Layer 2\nRAG Triad\nRelevance · Groundedness · Clarity" {
    style: { fill: "#fff1f2"; stroke: "#fca5a5"; border-radius: 8 }
  }
  l3: "Layer 3\nQuality Score\nFactuality · Completeness · Groundedness" {
    style: { fill: "#fff1f2"; stroke: "#fca5a5"; border-radius: 8 }
  }
  score: "최종 점수 집계\nsyntax×0.1 + stats×0.1\n+ rag×0.4 + quality×0.4" {
    style: {
      fill: "#fef3c7"
      stroke: "#f59e0b"
      border-radius: 8
      bold: true
    }
  }
  db4: "qa_eval_results\nfinal_score · final_grade" {
    shape: cylinder
    style: { fill: "#ede9fe"; stroke: "#7c3aed" }
  }

  l1a -> l1b
  l1b -> l2
  l2 -> l3
  l3 -> score
  score -> db4
}

# ── STEP 5: 대시보드 ─────────────────────────────────────
s5: "STEP 5  ·  대시보드" {
  style: {
    fill: "#f8fafc"
    stroke: "#6366f1"
    stroke-width: 2
    stroke-dash: 4
    border-radius: 12
    font-size: 13
    bold: true
  }

  api: "GET /api/dashboard/metrics\nSupabase 집계" {
    style: { fill: "#eef2ff"; stroke: "#818cf8"; border-radius: 8 }
  }
  view: "총 QA · 평균 점수 · 등급 분포\n최근 실행 이력 · 점수 추이" {
    shape: oval
    style: {
      fill: "#eef2ff"
      stroke: "#6366f1"
      stroke-width: 2
      bold: true
    }
  }

  api -> view
}

# ── 스텝 간 연결 ─────────────────────────────────────────
upload -> s1.parse

s1.db1 -> s2.pass1

s2.db2 -> s3.filter

s3.db3 -> s4.l1a

s4.db4 -> s5.api
